substep "ohmyzsh"
if [ -d ~/.oh-my-zsh ]; then
  warn "oh-my-zsh appears to already be installed ➡ skipping install"
else
  warn "Running sh -c \"\$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\""
  warn "Run 'exit' once oh-my-zsh finishes installing to return to this shell and finish fettling"
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi
substep_done "ohmyzsh ➡ complete"
